# Laravel
APP_NAME="HELPDEX API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Con php artisan serve: http://localhost:8000. Con Laravel Herd: http://helpdex.test (o el dominio de herd link)
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
SESSION_DRIVER=file

# AutoTask (Datto PSA) — REST API
# Doc: https://www.autotask.net/help/developerhelp/Content/APIs/REST/General_Topics/REST_Security_Auth.htm
#
# Requisitos (401 = revisar esto):
# 1) Usuario = recurso con nivel "API User (API-only)" (Admin > Resources > [recurso] > Security).
# 2) Tracking identifier obligatorio: en la pestaña Security del recurso. Tipos: "Custom (Internal Integration)" o "Vendor".
#    Quien tenga HR Security puede darte el Tracking ID; los API-only no tienen acceso a la UI.
# 3) Zone URL = la de tu cuenta. Si no la sabes: GET /api/tickets/zone-info?username=TU_USER
# 4) TLS 1.2 requerido por Datto; la API no usa SSO (la contraseña del API user no expira por SSO).
#
# Zone URL: con /atservicesrest (ej. https://webservices14.autotask.net/atservicesrest)
AUTOTASK_ZONE_URL=https://webservices3.autotask.net/atservicesrest
# Username del recurso API User (ej. apiuser@empresa.com)
AUTOTASK_USERNAME=
# Secret = contraseña de ese recurso. Si tiene # o = usa comillas: AUTOTASK_SECRET="clave#123"
AUTOTASK_SECRET=
# APIIntegrationcode = Tracking identifier (pestaña Security del API User)
AUTOTASK_INTEGRATION_CODE=
AUTOTASK_CACHE_TTL=60
# En Windows si falla certificado SSL: AUTOTASK_VERIFY_SSL=false
AUTOTASK_VERIFY_SSL=false
# Filtrar tickets por colas (Level I, Level II, Level III, Monitoring Alerts). IDs en AutoTask: Admin > Service Desk > Queues. Ej: 123,456,789
AUTOTASK_QUEUE_IDS=

# IA — Sugerencias y chat (OpenAI). Si la key tiene #, usa comillas: OPENAI_API_KEY="sk-..."
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
