# Laravel
APP_NAME="HELPDEX API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
SESSION_DRIVER=file

# AutoTask (Datto PSA) — Fase 1
# Zone URL: con /atservicesrest (ej. https://webservices14.autotask.net/atservicesrest) o solo dominio (ej. https://webservices3.autotask.net)
AUTOTASK_ZONE_URL=https://webservices3.autotask.net/atservicesrest
AUTOTASK_USERNAME=
# Si el secret contiene # u otros caracteres especiales, ponlo entre comillas: AUTOTASK_SECRET="tu#secret"
AUTOTASK_SECRET=
AUTOTASK_INTEGRATION_CODE=
AUTOTASK_CACHE_TTL=60
# En Windows si falla SSL: AUTOTASK_VERIFY_SSL=false
AUTOTASK_VERIFY_SSL=false

# IA — Sugerencias y chat (OpenAI). Si la key tiene #, usa comillas: OPENAI_API_KEY="sk-..."
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
